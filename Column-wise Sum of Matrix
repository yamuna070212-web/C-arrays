#include <stdio.h>

int main()
{
    int a[3][3], i, j, sum;

    printf("Enter 3x3 Matrix:\n");

    for(i = 0; i < 3; i++)
        for(j = 0; j < 3; j++)
            scanf("%d", &a[i][j]);

    for(j = 0; j < 3; j++)
    {
        sum = 0;

        for(i = 0; i < 3; i++)
            sum += a[i][j];

        printf("Sum of Column %d = %d\n", j + 1, sum);
    }

    return 0;
}
