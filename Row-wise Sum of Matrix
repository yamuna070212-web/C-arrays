#include <stdio.h>

int main()
{
    int a[3][3], i, j, sum;

    printf("Enter 3x3 Matrix:\n");

    for(i = 0; i < 3; i++)
        for(j = 0; j < 3; j++)
            scanf("%d", &a[i][j]);

    for(i = 0; i < 3; i++)
    {
        sum = 0;

        for(j = 0; j < 3; j++)
            sum += a[i][j];

        printf("Sum of Row %d = %d\n", i + 1, sum);
    }

    return 0;
}
Sample Output
Enter 3x3 Matrix:
1 2 3
4 5 6
7 8 9

