#include <stdio.h>

int main()
{
    int arr[5], i, j, key;

    printf("Enter 5 Elements:\n");

    for(i = 0; i < 5; i++)
        scanf("%d", &arr[i]);

    for(i = 1; i < 5; i++)
    {
        key = arr[i];
        j = i - 1;

        while(j >= 0 && arr[j] > key)
        {
            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = key;
    }

    printf("Sorted Array:\n");

    for(i = 0; i < 5; i++)
        printf("%d ", arr[i]);

    return 0;
}
Sample Output
Enter 5 Elements:
25 15 35 5 45

Sorted Array:
5 15 25 35 45
