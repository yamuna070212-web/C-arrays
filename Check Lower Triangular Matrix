#include <stdio.h>

int main()
{
    int a[3][3], i, j, lower = 1;

    printf("Enter 3x3 Matrix:\n");

    for(i = 0; i < 3; i++)
        for(j = 0; j < 3; j++)
            scanf("%d", &a[i][j]);

    for(i = 0; i < 3; i++)
    {
        for(j = i + 1; j < 3; j++)
        {
            if(a[i][j] != 0)
                lower = 0;
        }
    }

    if(lower)
        printf("Lower Triangular Matrix");
    else
        printf("Not a Lower Triangular Matrix");

    return 0;
}
