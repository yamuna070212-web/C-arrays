#include <stdio.h>

int main()
{
    int a[2][2], b[2][2], i, j, equal = 1;

    printf("Enter First Matrix:\n");

    for(i = 0; i < 2; i++)
        for(j = 0; j < 2; j++)
            scanf("%d", &a[i][j]);

    printf("Enter Second Matrix:\n");

    for(i = 0; i < 2; i++)
        for(j = 0; j < 2; j++)
            scanf("%d", &b[i][j]);

    for(i = 0; i < 2; i++)
    {
        for(j = 0; j < 2; j++)
        {
            if(a[i][j] != b[i][j])
                equal = 0;
        }
    }

    if(equal)
        printf("Matrices are Equal");
    else
        printf("Matrices are Not Equal");

    return 0;
}
Sample Output
Matrices are Equal
