#include <stdio.h>

int main()
{
    int arr[10], n, i, j, k;

    printf("Enter Number of Elements: ");
    scanf("%d", &n);

    printf("Enter Elements:\n");

    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    for(i = 0; i < n; i++)
    {
        for(j = i + 1; j < n;)
        {
            if(arr[i] == arr[j])
            {
                for(k = j; k < n - 1; k++)
                    arr[k] = arr[k + 1];

                n--;
            }
            else
            {
                j++;
            }
        }
    }

    printf("Array After Removing Duplicates:\n");

    for(i = 0; i < n; i++)
        printf("%d ", arr[i]);

    return 0;
}
