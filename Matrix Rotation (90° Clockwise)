#include <stdio.h>

int main()
{
    int a[3][3], i, j;

    printf("Enter 3x3 Matrix:\n");

    for(i = 0; i < 3; i++)
        for(j = 0; j < 3; j++)
            scanf("%d", &a[i][j]);

    printf("Matrix after 90 Degree Clockwise Rotation:\n");

    for(i = 0; i < 3; i++)
    {
        for(j = 2; j >= 0; j--)
        {
            printf("%d ", a[j][i]);
        }
        printf("\n");
    }

    return 0;
}
Sample Output
Enter 3x3 Matrix:
1 2 3
4 5 6
7 8 9

Matrix after 90 Degree Clockwise Rotation:
7 4 1
8 5 2
9 6 3
