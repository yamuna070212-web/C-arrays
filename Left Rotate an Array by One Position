#include <stdio.h>

int main()
{
    int arr[5], i, first;

    printf("Enter 5 Elements:\n");

    for(i = 0; i < 5; i++)
        scanf("%d", &arr[i]);

    first = arr[0];

    for(i = 0; i < 4; i++)
        arr[i] = arr[i + 1];

    arr[4] = first;

    printf("Array After Left Rotation:\n");

    for(i = 0; i < 5; i++)
        printf("%d ", arr[i]);

    return 0;
}
Sample Output
Enter 5 Elements:
10 20 30 40 50

Array After Left Rotation:
20 30 40 50 10
