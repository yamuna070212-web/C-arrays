#include <stdio.h>

int main()
{
    int a[2][2], i, j;

    printf("Enter Matrix:\n");

    for(i = 0; i < 2; i++)
        for(j = 0; j < 2; j++)
            scanf("%d", &a[i][j]);

    printf("Transpose Matrix:\n");

    for(i = 0; i < 2; i++)
    {
        for(j = 0; j < 2; j++)
            printf("%d ", a[j][i]);

        printf("\n");
    }

    return 0;
}
Sample Output
Enter Matrix:
1 2
3 4

Transpose Matrix:
1 3
2 4
