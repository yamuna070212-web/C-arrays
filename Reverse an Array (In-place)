#include <stdio.h>

int main()
{
    int arr[5], i, temp;

    printf("Enter 5 Elements:\n");

    for(i = 0; i < 5; i++)
        scanf("%d", &arr[i]);

    for(i = 0; i < 5 / 2; i++)
    {
        temp = arr[i];
        arr[i] = arr[4 - i];
        arr[4 - i] = temp;
    }

    printf("Reversed Array:\n");

    for(i = 0; i < 5; i++)
        printf("%d ", arr[i]);

    return 0;
}
Sample Output
Enter 5 Elements:
10 20 30 40 50

Reversed Array:
50 40 30 20 10
