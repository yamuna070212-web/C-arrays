#include <stdio.h>

int main()
{
    int arr[5], i, last;

    printf("Enter 5 Elements:\n");

    for(i = 0; i < 5; i++)
        scanf("%d", &arr[i]);

    last = arr[4];

    for(i = 4; i > 0; i--)
        arr[i] = arr[i - 1];

    arr[0] = last;

    printf("Array After Right Rotation:\n");

    for(i = 0; i < 5; i++)
        printf("%d ", arr[i]);

    return 0;
}
Sample Output
Enter 5 Elements:
10 20 30 40 50

Array After Right Rotation:
50 10 20 30 40
